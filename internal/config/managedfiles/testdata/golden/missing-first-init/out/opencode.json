{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "specgraph": {
      "enabled": true,
      "headers": {
        "Authorization": "Bearer {env:SPECGRAPH_API_KEY}",
        "X-Specgraph-Project": "captureslug"
      },
      "type": "remote",
      "url": "http://localhost:9090/mcp/"
    }
  },
  "plugin": [
    "./.specgraph/agents/opencode/specgraph.ts"
  ]
}
