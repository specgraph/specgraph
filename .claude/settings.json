{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'FILE=$(echo \"$TOOL_INPUT\" | jq -r \".file_path // empty\") && [[ \"$FILE\" == */gen/* ]] && echo \"BLOCKED: gen/ is auto-generated by buf. Edit proto/ files instead and run /buf-regen.\" && exit 1 || exit 0'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'FILE=$(echo \"$TOOL_INPUT\" | jq -r \".file_path // empty\") && [[ \"$FILE\" == *.go ]] && [[ -f \"$FILE\" ]] && gofmt -w \"$FILE\" || true'"
          }
        ]
      }
    ]
  }
}
