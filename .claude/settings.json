{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "task lint 2>/dev/null || true",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "if echo \"$CLAUDE_TOOL_PARAM_file_path\" | grep -q '/gen/'; then echo 'BLOCK: gen/ files are auto-generated \u2014 edit .proto files instead'; exit 2; fi",
            "type": "command"
          }
        ],
        "matcher": "Edit|Write"
      }
    ]
  }
}
