[0.002, "o", "\u001b[?2026h\u001b[2D\u001b[5B\u001b[2J\u001b[3J\u001b[H\u001b[38;2;215;119;87m ▐\u001b[48;2;0;0;0m▛███▜\u001b[49m▌\u001b[3C\u001b[39m\u001b[1mClaude\u001b[1CCode\u001b[1C\u001b[22m\u001b[38;2;153;153;153mv2.1.89\u001b[39m\r\r\n\u001b[38;2;215;119;87m▝▜\u001b[48;2;0;0;0m█████\u001b[49m▛▘\u001b[2C\u001b[38;2;153;153;153mSonnet\u001b[1C4.6\u001b[1C·\u001b[1CClaude\u001b[1CEnterprise\u001b[39m\r\r\n\u001b[38;2;215;119;87m \u001b[1C▘▘\u001b[1C▝▝\u001b[4C\u001b[38;2;153;153;153m/Volumes/Code/github.com/specgraph-demo\u001b[39m\r\r\n\r\r\n\u001b[38;2;78;186;101m⏺\u001b[1C\u001b[39m\u001b[1mBash\u001b[22m(./specgraph\u001b[1Cshow\u001b[1Cinbound-webhooks\u001b[1C&&\u001b[1C./specgraph\u001b[1Clist\u001b[1C--json)\r\r\n\u001b[38;2;153;153;153m \u001b[1C⎿\u001b[1C \u001b[39m#\u001b[1Cinbound-webhooks\r\r\n\r\r\n\u001b[5C>\u001b[1CEnable\u001b[1CSpecGraph\u001b[1Cto\u001b[1Creceive\u001b[1Cpush-based\u001b[1Cnotifications\u001b[1Cfrom\u001b[1Cexternal\u001b[1Csystems\u001b[1C(GH,\u001b[1CADO,\u001b[1CDiscord,\u001b[1CSlack)\u001b[1Cto\u001b[1Cupdate\u001b[1Cspec\u001b[1Ca\r\r\n\u001b[5C\u001b[2m…\u001b[1C+36\u001b[1Clines\u001b[1C(ctrl+o\u001b[1Cto\u001b[1Cexpand)\u001b[22m\r\r\n\r\r\n\u001b[38;2;255;255;255m⏺\u001b[1C\u001b[39mOnly\u001b[1Cone\u001b[1Cspec\u001b[1Cin\u001b[1Cthe\u001b[1Cgraph\u001b[1C—\u001b[1Cno\u001b[1Coverlap\u001b[1Cto\u001b[1Cworry\u001b[1Cabout.\u001b[1CDispatching\u001b[1Ca\u001b[1Ccodebase\u001b[1Cscan\u001b[1Cwhile\u001b[1Cwe\u001b[1Cstart."]
[0.000, "o", "\r\r\n\r\r\n\u001b[38;2;78;186;101m⏺\u001b[1C\u001b[39m\u001b[1mAgent\u001b[22m(Scan\u001b[1Ccodebase\u001b[1Cfor\u001b[1Cwebhook/sync\u001b[1Ccontext)\r\r\n\u001b[38;2;153;153;153m \u001b[1C⎿\u001b[1C \u001b[39mBackgrounded\u001b[1Cagent\u001b[38;2;153;153;153m (↓\u001b[1Cto\u001b[1Cmanage\u001b[1C·\u001b[1Cctrl+o\u001b[1Cto\u001b[1Cexpand)\u001b[39m\r\r\n\r\r\n\u001b[38;2;255;255;255m⏺\u001b[1C\u001b[39mPartner\u001b[1Cposture.\u001b[1CLet\u001b[1Cme\u001b[1Cpropose\u001b[1Cscope\u001b[1C—\u001b[1Cyou\u001b[1Cconfirm,\u001b[1Cadjust,\u001b[1Cor\u001b[1Cpush\u001b[1Cback\u001b[1Cbefore\u001b[1Cwe\u001b[1Cmove\u001b[1Cto\u001b[1Capproaches.\r\r\n\r\r\n\u001b[2C---\r\r\n\u001b[2C\u001b[1mScope\u001b[1CIn\u001b[1C\u001b[22m(proposed):\r\r\n\r\r\n\u001b[2C-\u001b[1CHTTP\u001b[1Cendpoint(s)\u001b[1Cto\u001b[1Creceive\u001b[1Cinbound\u001b[1Cwebhook\u001b[1Cpayloads\r\r\n\u001b[2C-\u001b[1CSignature\u001b[1Cverification\u001b[1Cper\u001b[1Cprovider\u001b[1C(HMAC-SHA256\u001b[1Cfor\u001b[1CGH,\u001b[1Cequivalent\u001b[1Cfor\u001b[1CADO)\r\r\n\u001b[2C-\u001b[1CProvider\u001b[1Cabstraction\u001b[1C—\u001b[1Can\u001b[1Cinterface\u001b[1Cboth\u001b[1CGH\u001b[1Cand\u001b[1CADO\u001b[1Cimplement,\u001b[1Cextensible\u001b[1Cto\u001b[1Cfuture\u001b[1Csources\r\r\n\u001b[2C-\u001b[1CEvent\u001b[1Crouting:\u001b[1Cmap\u001b[1Cprovider-specific\u001b[1Cevent\u001b[1Ctypes\u001b[1Cto\u001b[1CSpecGraph\u001b[1Cstate\u001b[1Cmutations\u001b[1C(spec/slice\u001b[1Cstage\u001b[1Ctransitions,\u001b[1Cstatus\u001b[1Cupdates)\r\r\n\u001b[2C-\u001b[1C"]
[0.000, "o", "GitHub\u001b[1Cprovider:\u001b[1CPR/issue\u001b[1Cevents\u001b[1C→\u001b[1Cspec\u001b[1Cstate\r\r\n\u001b[2C-\u001b[1CADO\u001b[1Cprovider:\u001b[1Cwork\u001b[1Citem/PR\u001b[1Cevents\u001b[1C→\u001b[1Cspec\u001b[1Cstate\r\r\n\u001b[2C-\u001b[1CNew\u001b[1Cproto\u001b[1Cservice\u001b[1Cdefinition\u001b[1Cfor\u001b[1Cthe\u001b[1Cwebhook\u001b[1Csurface\r\r\n\r\r\n\u001b[2C\u001b[1mScope\u001b[1COut\u001b[1C\u001b[22m(proposed):\r\r\n\r\r\n\u001b[2C-\u001b[1CDiscord,\u001b[1CSlack\u001b[1Cproviders\u001b[1C(future\u001b[1Cspec)\r\r\n\u001b[2C-\u001b[1CKafka/message\u001b[1Cqueue\u001b[1Clayer\u001b[1C(your\u001b[1Ckill\u001b[1Ccondition\u001b[1C#2\u001b[1C—\u001b[1Cif\u001b[1Cwe\u001b[1Cneed\u001b[1Cit,\u001b[1Cthis\u001b[1Cspec\u001b[1Cgets\u001b[1Csuperseded)\r\r\n\u001b[2C-\u001b[1COutbound\u001b[1Cwebhooks\u001b[1C(SpecGraph\u001b[1Cnotifying\u001b[1Cexternal\u001b[1Csystems\u001b[1C—\u001b[1Cdifferent\u001b[1Cspec)\r\r\n\u001b[2C-\u001b[1CWebhook\u001b[1Cregistration\u001b[1CUI\u001b[1Cor\u001b[1Cmanagement\u001b[1CAPI\u001b[1C(CRUD\u001b[1Cfor\u001b[1Cregistrations\u001b[1C—\u001b[1Cfuture)\r\r\n\u001b[2C-\u001b[1CRetry/replay\u001b[1Cinfrastructure\u001b[1Cfor\u001b[1Cfailed\u001b[1Cdeliveries\r\r\n\u001b[2C-\u001b[1CEvent\u001b[1Caudit\u001b[1Clog\u001b[1C/\u001b[1Cpersistent\u001b[1Cevent\u001b[1Cstore\r\r\n\r\r\n\u001b[2CHow\u001b[1Cdoes\u001b[1Cthat\u001b[1Cland?\u001b[1CAnything\u001b[1Cyou'd\u001b[1Cmove\u001b[1Cin\u001b[1Cor\u001b[1Cout?\r\r\n\r\r\n\u001b[38;2;153;153;153m✻\u001b[1CBrewed\u001b[1Cfor\u001b[1C39s\u001b[1C·\u001b[1C1\u001b[1Cloc"]
