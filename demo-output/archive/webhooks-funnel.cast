[0.000, "o", "C⎿\u001b[1C \u001b[39m#\u001b[1Cinbound-webhooks\r\r\n\r\r\n\u001b[5C>\u001b[1CEnable\u001b[1CSpecGraph\u001b[1Cto\u001b[1Creceive\u001b[1Cpush-based\u001b[1Cnotifications\u001b[1Cfrom\u001b[1Cexternal\u001b[1Csystems\u001b[1C(GH,\u001b[1CADO,\u001b[1CDiscord,\u001b[1CSlack)\u001b[1Cto\u001b[1Cupdate\u001b[1Cspec\u001b[1Ca\r\r\n\u001b[5C\u001b[2m…\u001b[1C+68\u001b[1Clines\u001b[1C(ctrl+o\u001b[1Cto\u001b[1Cexpand)\u001b[22m\r\r\n\r\r\n\u001b[38;2;255;255;255m⏺\u001b[1C\u001b[38;2;177;185;249m★\u001b[1CInsight\u001b[1C─────────────────────────────────────\u001b[39m\r\r\n\u001b[2CSpecify\u001b[1Cis\u001b[1Cthe\u001b[1Cstage\u001b[1Cwhere\u001b[1Cambiguity\u001b[1Cbecomes\u001b[1Cexpensive\u001b[1C—\u001b[1Cvague\u001b[1Cinterface\u001b[1Ccontracts\u001b[1Cmean\u001b[1Cimplementers\u001b[1Cmake\u001b[1Cdifferent\r\r\n\u001b[2Cassumptions.\u001b[1CThe\u001b[1Cgoal\u001b[1Chere\u001b[1Cis\u001b[1Cthat\u001b[1Ctwo\u001b[1Cpeople\u001b[1Ccould\u001b[1Cimplement\u001b[1Cthis\u001b[1Cspec\u001b[1Cindependently\u001b[1Cand\u001b[1Cproduce\u001b[1Cinteroperable\u001b[1Ccode.\u001b[1CInterface\r\r\n\u001b[3Ccontracts,\u001b[1Cerror\u001b[1Cconditions,\u001b[1Cand\u001b[1Cverify\u001b[1Ccriteria\u001b[1Care\u001b[1Cthe\u001b[1Ctools\u001b[1Cthat\u001b[1Cmake\u001b[1Cthat\u001b[1Cpossible.\r\r\n\u001b[2C\u001b[38;2;177;185;249m────────────────"]
[0.000, "o", "─────────────────────────────────\u001b[39m\r\r\n\r\r\n\u001b[2C---\r\r\n\u001b[2C\u001b[1mInterface\u001b[1CContract\u001b[1C\u001b[22m—\u001b[1Cdraft\u001b[1Cbased\u001b[1Con\u001b[1Cthe\u001b[1CShape\u001b[1Coutput:\r\r\n\r\r\n\u001b[2C---\r\r\n\u001b[2C\u001b[1mHTTP\u001b[1CEndpoints\u001b[22m\r\r\n\r\r\n\u001b[2CPOST\u001b[1C/api/webhooks/github\r\r\n\u001b[2CPOST\u001b[1C/api/webhooks/ado\r\r\n\r\r\n\u001b[2CBoth\u001b[1Croutes:\r\r\n\u001b[2C-\u001b[1CNo\u001b[1C\u001b[38;2;177;185;249mauthMW\u001b[1C\u001b[39m—\u001b[1Csignature/secret\u001b[1CIS\u001b[1Cthe\u001b[1Cauth\r\r\n\u001b[2C-\u001b[1CPayload\u001b[1Csize\u001b[1Climit\u001b[1Cenforced\u001b[1Cfirst\u001b[1C(before\u001b[1Creading\u001b[1Cbody),\u001b[1Creturns\u001b[1C\u001b[38;2;177;185;249m413\u001b[39m\r\r\n\u001b[2C-\u001b[1CRate\u001b[1Climiting\u001b[1Cenforced\u001b[1Cnext\u001b[1C(per-IP),\u001b[1Creturns\u001b[1C\u001b[38;2;177;185;249m429\u001b[39m\r\r\n\u001b[2C-\u001b[1CProject\u001b[1Cscoped\u001b[1Cvia\u001b[1C\u001b[38;2;177;185;249mX-Specgraph-Project\u001b[1C\u001b[39mheader\u001b[1C(existing\u001b[1Cpattern)\r\r\n\r\r\n\u001b[2CGitHub-specific:\r\r\n\u001b[2C-\u001b[1CRequired\u001b[1Cheaders:\u001b[1C\u001b[38;2;177;185;249mX-Hub-Signature-256\u001b[39m,\u001b[1C\u001b[38;2;177;185;249mX-GitHub-Event\u001b[39m,\u001b[1C\u001b[38;2;177;185;249mX-GitHub-Delivery\u001b[39m\r\r\n\u001b[2C-\u001b[1CValidation:\u001b[1C\u001b[38"]
