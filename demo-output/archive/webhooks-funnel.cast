[0.964, "o", "\u001b[?2026h\u001b[2D\u001b[5B\r\u001b[6A  Six surfaces covered: HTTP endpoints with full response codes, \u001b[38;2;177;185;249mWebhookProvider\u001b[39m with error semantics,                           \r\u001b[1B  \u001b[38;2;177;185;249mWebhookEvent\u001b[39m/\u001b[38;2;177;185;249mWebhookEventRecord\u001b[1C\u001b[39mwith\u001b[1C\u001b[38;2;177;185;249mRawPayload\u001b[1C\u001b[39mand\u001b[1C\u001b[38;2;177;185;249mDisposition\u001b[39m,\u001b[1C\u001b[38;2;177;185;249mWebhookBackend\u001b[39m,\u001b[1C\u001b[38;2;177;185;249mWebhookConfig\u001b[39m,\u001b[1Cand\u001b[1C\u001b[38;2;177;185;249mRegisterWebhookHandlers\r\u001b[1B\u001b[39m  with the no-authMW contract structurally encoded. Sentinel errors defined for all failure modes. One observation:              \r\u001b[2C\u001b[1B\u001b[38;2;177;185;249mCheckContentHash\u001b[39m and \u001b[38;2;177;185;249mStoreWebhookEvent\u001b[39m are separate operations\u001b[1C—\u001b[1Cthere's\u001b[1Ca\u001b[1Cnarrow TOCTOU window under concurrent redelivery. \r\u001b[2C\u001b[1BAt-least-once semantics are acceptable for webhooks; worth\u001b[1Cnoting\u001b[1Cfor\u001b[1Cthe\u001b[1Cimplementer\u001b[1Cbut\u001b[1Cnot\u001b[1Ca\u001b[1Ccontract\u001b[1Cgap.\r\u001b[2C\u001b[1B                                            "]
