[0.098, "o", "\u001b[?2026h\u001b[2D\u001b[4B\u001b[2J\u001b[3J\u001b[H\u001b[38;2;215;119;87m ▐\u001b[48;2;0;0;0m▛███▜\u001b[49m▌\u001b[3C\u001b[39m\u001b[1mClaude\u001b[1CCode\u001b[1C\u001b[22m\u001b[38;2;153;153;153mv2.1.89\u001b[39m\r\r\n\u001b[38;2;215;119;87m▝▜\u001b[48;2;0;0;0m█████\u001b[49m▛▘\u001b[2C\u001b[38;2;153;153;153mOpus\u001b[1C4.6\u001b[1Cwith\u001b[1Chigh\u001b[1Ceffort\u001b[1C·\u001b[1CClaude\u001b[1CEnterprise\u001b[39m\r\r\n\u001b[38;2;215;119;87m \u001b[1C▘▘\u001b[1C▝▝\u001b[4C\u001b[38;2;153;153;153m/Volumes/Code/github.com/specgraph-demo\u001b[39m\r\r\n\r\r\n\u001b[2C\u001b[38;2;153;153;153mRead\u001b[1C\u001b[1m3\u001b[22m files\u001b[1C(ctrl+o\u001b[1Cto\u001b[1Cexpand)\u001b[39m\r\r\n\r\r\n\u001b[38;2;78;186;101m⏺\u001b[1C\u001b[39m\u001b[1mBash\u001b[22m(./bin/specgraph\u001b[1Cshow\u001b[1Cevent-ingestion-pipeline\u001b[1C2>&1)\r\r\n\u001b[38;2;153;153;153m \u001b[1C⎿\u001b[1C \u001b[39m#\u001b[1Cevent-ingestion-pipeline\r\r\n\r\r\n\u001b[5C>\u001b[1CUnified\u001b[1Cevent\u001b[1Cingestion\u001b[1Cpipeline\u001b[1Creplacing\u001b[1Craw\u001b[1CHTTP\u001b[1Chandlers\u001b[1Cwith\u001b[1Cschema\u001b[1Cvalidation,\u001b[1Cdead-letter\r\r\n\u001b[5C\u001b[2m…\u001b[1C+9\u001b[1Clines\u001b[1C(ctrl+o\u001b[1Cto\u001b[1Cexpand)\u001b[22m\r\r\n\r\r\n\u001b[38;2;255;255;255m⏺\u001b[1C\u001b[39mNow\u001b[1Clet\u001b[1Cme\u001b[1Claunch\u001b[1Cbackground\u001b[1Cresearch\u001b[1Cwhile\u001b[1Cwe\u001b[1Cstart\u001b[1Cshaping.\r\r\n\r\r"]
