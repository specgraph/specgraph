[0.000, "o", "Cdiscussion,\u001b[1Chere\u001b[1Care\u001b[1Cthe\u001b[1Cdecisions\u001b[1Cto\u001b[1Crecord:\r\r\n\r\r\n\u001b[2C\u001b[1m1.\u001b[1C\u001b[38;2;177;185;249mcloudevents-canonical-envelope\u001b[22m\u001b[39m\r\r\n\u001b[2C-\u001b[1C\u001b[1mDecision:\u001b[1C\u001b[22mAll\u001b[1Cinbound\u001b[1Cevents\u001b[1Care\u001b[1Cnormalized\u001b[1Cto\u001b[1CCloudEvents\u001b[1Cv1.0\u001b[1Cformat\u001b[1Cat\u001b[1Cthe\u001b[1Cadapter\u001b[1Cboundary\u001b[1Cbefore\r\r\n\u001b[2Centering\u001b[1Cthe\u001b[1Cpipeline.\r\r\n\u001b[2C-\u001b[1C\u001b[1mRationale:\u001b[1C\u001b[22mCloudEvents\u001b[1Cis\u001b[1Cthe\u001b[1CCNCF\u001b[1Cstandard\u001b[1Cfor\u001b[1Cevent\u001b[1Cdescription.\u001b[1CNormalizing\u001b[1Cat\u001b[1Cthe\u001b[1Cedge\u001b[1Cmeans\u001b[1Cthe\r\r\n\u001b[2Cpipeline\u001b[1Cinternals\u001b[1Conly\u001b[1Cdeal\u001b[1Cwith\u001b[1Cone\u001b[1Cformat\u001b[1C--\u001b[1Cprovider-specific\u001b[1Cwire\u001b[1Cformats\u001b[1Care\u001b[1Ccontained\u001b[1Cin\u001b[1Cadapters.\r\r\n\u001b[2CThe\u001b[1Csuperseded\u001b[1C\u001b[38;2;177;185;249minbound-webhooks\u001b[1C\u001b[39mused\u001b[1Ca\u001b[1Ccustom\u001b[1C\u001b[38;2;177;185;249mWebhookEvent\u001b[1C\u001b[39mtype;\u001b[1CCloudEvents\u001b[1Cgives\u001b[1Cus\u001b[1Cthe\u001b[1Csame\r\r\n\u001b[2Cnormalization\u001b[1Cwith\u001b[1Can\u001b[1Cindustry-standard\u001b[1Cenvelope.\r\r\n\r\r\n\u001b[2C\u001b[1m2.\u001b[1C\u001b[38;2;177;185;249mlinear-pipeline-over-middleware-or-bus\u001b[22m\u001b[39m\r\r\n\u001b[2C-\u001b[1C\u001b[1mDecision:"]
