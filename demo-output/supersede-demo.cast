[0.000, "o", "───────┴─────────┘\r\r\n\r\r\n\u001b[2CNow\u001b[1Cexecuting\u001b[1Cthe\u001b[1Csupersede,\u001b[1Cthen\u001b[1Crouting\u001b[1Cto\u001b[1Cshape.\r\r\n\r\r\n\u001b[38;2;78;186;101m⏺\u001b[1C\u001b[39m\u001b[1mBash\u001b[22m(./bin/specgraph\u001b[1Csupersede\u001b[1Cinbound-webhooks\u001b[1C--with\u001b[1Cevent-ingestion-pipeline\u001b[1C2>&1)\r\r\n\u001b[38;2;153;153;153m \u001b[1C⎿\u001b[1C \u001b[39mSuperseded:\u001b[1Cinbound-webhooks\u001b[1C(lifecycle=SPEC_LIFECYCLE_TASK)\r\r\n\u001b[5CCreated:\u001b[4Cevent-ingestion-pipeline\u001b[1C(lifecycle=SPEC_LIFECYCLE_TASK,\u001b[1Cstage=spark)\r\r\n\r\r\n\u001b[38;2;255;255;255m⏺\u001b[1C\u001b[39mSupersede\u001b[1Ccomplete\u001b[1C—\u001b[1C\u001b[38;2;177;185;249minbound-webhooks\u001b[1C\u001b[39mis\u001b[1Cnow\u001b[1Csuperseded,\u001b[1Cand\u001b[1C\u001b[38;2;177;185;249mevent-ingestion-pipeline\u001b[1C\u001b[39mcarries\u001b[1Cthe\u001b[1Clineage.\r\r\n\u001b[2CNow\u001b[1Clet's\u001b[1Cshape\u001b[1Cthe\u001b[1Creplacement.\r\r\n\r\r\n\u001b[38;2;78;186;101m⏺\u001b[1C\u001b[39m\u001b[1mSkill\u001b[22m(specgraph-shape)\r\r\n\u001b[38;2;153;153;153m \u001b[1C⎿\u001b[1C \u001b[39mSuccessfully\u001b[1Cloaded\u001b[1Cskill\r\r\n\r\r\n\u001b[38;2;255;255;255m⏺\u001b[1C\u001b[39mLet\u001b[1Cme\u001b[1Cload\u001b[1Cthe\u001b[1Creferences\u001b[1Cand\u001b[1Ccurrent\u001b[1Cspec\u001b[1Cstate,\u001b[1Cthen\u001b[1Cstar"]
