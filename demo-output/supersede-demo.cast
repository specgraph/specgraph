[0.001, "o", "\r\n\u001b[2C\u001b[1m4.\u001b[1C\u001b[38;2;177;185;249mdead-letter-at-explicit-failure-points\u001b[22m\u001b[39m\r\r\n\u001b[2C-\u001b[1C\u001b[1mDecision:\u001b[1C\u001b[22mDead-letter\u001b[1Cstorage\u001b[1Ctaps\u001b[1Cat\u001b[1Ctwo\u001b[1Cexplicit\u001b[1Cpoints:\u001b[1Cschema\u001b[1Cvalidation\u001b[1Cfailure\u001b[1Cand\u001b[1Chandler\r\r\n\u001b[2Cprocessing\u001b[1Cfailure.\u001b[1CEach\u001b[1Cdead-letter\u001b[1Crecord\u001b[1Ccarries\u001b[1Cthe\u001b[1Coriginal\u001b[1CCloudEvent,\u001b[1Cfailure\u001b[1Creason,\u001b[1Cand\u001b[1Cstage\r\r\n\u001b[2Cwhere\u001b[1Cit\u001b[1Cfailed.\u001b[1CRejected\u001b[1Ccross-cutting\u001b[1Cdead-letter\u001b[1Cmiddleware\u001b[1C(obscures\u001b[1Cwhich\u001b[1Cstage\u001b[1Cfailed).\r\r\n\u001b[2C-\u001b[1C\u001b[1mRationale:\u001b[1C\u001b[22mTwo\u001b[1Cknown\u001b[1Cfailure\u001b[1Cmodes,\u001b[1Ctwo\u001b[1Cexplicit\u001b[1Ctaps.\u001b[1CMakes\u001b[1Cdebugging\u001b[1Cstraightforward\u001b[1C--\u001b[1Cyou\u001b[1Cknow\r\r\n\u001b[2Cexactly\u001b[1Cwhere\u001b[1Cand\u001b[1Cwhy\u001b[1Can\u001b[1Cevent\u001b[1Cwas\u001b[1Cdead-lettered.\u001b[1CThe\u001b[1Cmiddleware\u001b[1Capproach\u001b[1Cwould\u001b[1Chandle\u001b[1Cit\u001b[1Cgenerically\u001b[1Cbut\r\r\n\u001b[2Chide\u001b[1Cthe\u001b[1Cfailure\u001b[1Clocation\u001b[1Cbehind\u001b[1Cthe\u001b[1Cchain.\r\r\n\r\r\n\u001b[2CDo\u001b[1Cthese\u001b[1Ccapture\u001b[1Cthe\u001b[1Cchoices\u001b[1Caccurately,\u001b[1Cor\u001b[1Canything\u001b[1Cto\u001b[1Crevise?\r\r\n\r\r\n\u001b[38;2;78;186;101m⏺\u001b[1"]
