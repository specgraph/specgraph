[0.000, "o", "────────────\u001b[39m\r\r\n\u001b[2C\u001b[48;5;176m\u001b[38;5;235m Model: Opus 4.6 \u001b[48;5;238m\u001b[38;5;176m\u001b[38;5;255m Ctx: 65.9k \u001b[48;5;150m\u001b[38;5;238m\u001b[38;5;235m ⎇ feat/demo1 \u001b[48;5;210m\u001b[38;5;150m\u001b[38;5;235m (+2346,-0…\u001b[1C\u001b[49m\u001b[38;2;255;193;7mUpdate\u001b[1Cavailable!\u001b[1CRun:\u001b[1C\u001b[1mbrew\u001b[1Cupgrade\u001b[1Cclaude-code\u001b[22m\u001b[39m\r\r\n\u001b[2C\u001b[38;2;255;107;128m⏵⏵\u001b[1Cbypass\u001b[1Cpermissions\u001b[1Con\u001b[38;2;153;153;153m ·\u001b[1C\u001b[38;2;0;204;204m2\u001b[1Clocal\u001b[1Cagents\u001b[39m\r\r\n\u001b[2C\u001b[4A\u001b[?2026l"]
