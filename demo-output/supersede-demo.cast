[0.039, "o", "\u001b[?2026h\u001b[2D\u001b[4B\r\u001b[2C\u001b[6A-\u001b[1C\u001b[1mJSON Schema validation becomes a bottleneck\u001b[1C\u001b[22m--\u001b[1CSchema\u001b[1Cvalidation\u001b[1Cruns\u001b[1Con\u001b[1Cevery\u001b[1Cinbound\u001b[1Cevent\u001b[1Cbefore\r\u001b[1B  routing. Complex schemas or large payloads could add latency to the hot path. Mitigation: schema           \r\u001b[1B  compilation\u001b[1Cat\u001b[1Cstartup\u001b[1C(not\u001b[1Cper-request),\u001b[1Cpayload\u001b[1Csize\u001b[1Climits\u001b[1Calready\u001b[1Cenforced\u001b[1Cupstream.\r\u001b[1B                                                                                                             \r\u001b[1B\u001b[38;2;136;136;136m─────────────────────────────────────────────────────────────────────────────────────────────────────────────\r\u001b[1B\u001b[38;2;153;153;153m❯ \u001b[39m\u001b[7m \u001b[27m                                                    \r\r\n\u001b[38;2;136;136;136m────────────"]
