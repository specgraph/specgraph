[0.000, "o", "1Cpipeline\u001b[1Creplacing\u001b[1Craw\u001b[1CHTTP\u001b[1Chandlers\u001b[1Cwith\u001b[1Cschema\u001b[1Cvalidation,\u001b[1Cdead-letter\r\r\n\u001b[5C\u001b[2m…\u001b[1C+9\u001b[1Clines\u001b[1C(ctrl+o\u001b[1Cto\u001b[1Cexpand)\u001b[22m\r\r\n\r\r\n\u001b[38;2;255;255;255m⏺\u001b[1C\u001b[38;2;177;185;249m★\u001b[1CInsight\u001b[1C─────────────────────────────────────\u001b[39m\r\r\n\u001b[2C\u001b[1mSupersede\u001b[1C\u001b[22mis\u001b[1CSpecGraph's\u001b[1Clifecycle\u001b[1Cmechanism\u001b[1Cfor\u001b[1Creplacing\u001b[1Cdone\u001b[1Cspecs.\u001b[1CUnlike\u001b[1Camend\u001b[1C(which\u001b[1Cre-enters\u001b[1Can\r\r\n\u001b[2Cin-flight\u001b[1Cspec),\u001b[1Csupersede\u001b[1Ccreates\u001b[1Ca\u001b[1Cformal\u001b[1Clineage\u001b[1Cedge:\u001b[1Cthe\u001b[1Cnew\u001b[1Cspec\u001b[1Cinherits\u001b[1Ccontext\u001b[1Cfrom\u001b[1Cits\r\r\n\u001b[2Cpredecessor\u001b[1Cwhile\u001b[1Cthe\u001b[1Cold\u001b[1Cone\u001b[1Cis\u001b[1Cmarked\u001b[1Cas\u001b[1Csuperseded.\u001b[1CThis\u001b[1Cpreserves\u001b[1Cthe\u001b[1Cfull\u001b[1Cdecision\u001b[1Chistory\u001b[1C—\u001b[1Cyou\u001b[1Ccan\r\r\n\u001b[2Ctrace\u001b[1C\u001b[3mwhy\u001b[1C\u001b[23mthe\u001b[1Carchitecture\u001b[1Cevolved\u001b[1Cfrom\u001b[1Craw\u001b[1CHTTP\u001b[1Chandlers\u001b[1Cto\u001b[1Ca\u001b[1Cpipeline.\r\r\n\u001b[2C\u001b[38;2;177;185;249m─────────────────────"]
