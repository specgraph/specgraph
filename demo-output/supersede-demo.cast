[0.518, "o", "\u001b[?2026h\u001b[2D\u001b[4B\r\u001b[2C\u001b[13A-\u001b[1C\u001b[1mDecision:\u001b[1C\u001b[22mAll\u001b[1Cinbound\u001b[1Cevents\u001b[1Care\u001b[1Cnormalized\u001b[1Cto\u001b[1CCloudEvents\u001b[1Cv1.0\u001b[1Cformat\u001b[1Cat\u001b[1Cthe\u001b[1Cadapter\u001b[1Cboundary\u001b[1Cbefore\r\u001b[2C\u001b[1Bentering the pipeline. \u001b[1C      \u001b[1C   \u001b[1C          \u001b[1C  \u001b[1C           \u001b[1C    \u001b[1C      \u001b[1C  \u001b[1C   \u001b[1C       \u001b[1C        \u001b[1C      \r\u001b[2C\u001b[1B- \u001b[1mRationale:\u001b[1C\u001b[22mCloudEv\u001b[1Cnts\u001b[1Cis\u001b[1Cthe\u001b[1CCNCF\u001b[1Cstandard\u001b[1Cfor\u001b[1Cevent\u001b[1Cdescription.\u001b[1CNormalizing\u001b[1Cat\u001b[1Cthe\u001b[1Cedge\u001b[1Cmeans\u001b[1Cthe\r\u001b[2C\u001b[1Bpipeline internals only deal with one form\u001b[1Ct -- pro\u001b[1Cider-spec\u001b[1Cfic wire formats are contained\u001b[1Cin adapt\u001b[1Crs.\r\u001b[2C\u001b[1BThe sup\u001b[1Crsed\u001b[1Cd \u001b[38;2;177;185;249minbound-webhooks\u001b[39m used a custom \u001b[38;2;177;185;249mWebhookEvent\u001b[39m type; CloudEvents gives\u001b[1Cus \u001b[1Che same \u001b[1C         \r\u001b[2C\u001b[1Bnormalization with an industry-stan\u001b[1Card envelope.         \u001b[1C     \u001b[1C           \u001b[1C     \u001b[1C  \u001b[1C   \u001b[1C    \r\u001b[2C\u001b[1B             \u001b[1C    \u001b[1C  \u001b[1C                 \u001b[1C         \r\u001b[2C\u001b[1B\u001b[1m2. \u001b[38;2;177;1"]
