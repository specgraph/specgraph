[0.068, "o", "\u001b[?2026h\u001b[2D\u001b[4B\r\u001b[2C\u001b[6A-\u001b[1C\u001b[1mRationale:\u001b[1C\u001b[22mCloudEvents\u001b[1Cis\u001b[1Cthe\u001b[1CCNCF\u001b[1Cstandard\u001b[1Cfor\u001b[1Cevent\u001b[1Cdescription.\u001b[1CNormalizing\u001b[1Cat\u001b[1Cthe\u001b[1Cedge\u001b[1Cmeans\u001b[1Cthe\r\u001b[1B  pipeline internals only deal with one format -- provider-specific wire formats are contained in adapters.  \r\u001b[1B  The\u001b[1Csuperseded\u001b[1C\u001b[38;2;177;185;249minbound-webhooks\u001b[1C\u001b[39mused\u001b[1Ca\u001b[1Ccustom\u001b[1C\u001b[38;2;177;185;249mWebhookEvent\u001b[1C\u001b[39mtype;\u001b[1CCloudEvents\u001b[1Cgives\u001b[1Cus\u001b[1Cthe\u001b[1Csame\r\u001b[1B  normalization with an industry-standard envelope.                                                          \r\u001b[2C\u001b[1B                                                                                                         \r\u001b[1B\u001b[38;2;136;136;136m─────────────────────────────────────────────────────────────────────────────────────────────────"]
