[0.432, "o", "\u001b[?2026h\u001b[2D\u001b[4B\r\u001b[2C\u001b[6A-\u001b[1C\u001b[1mRouter pattern-matching expressiveness\u001b[1C\u001b[22m--\u001b[1CDispatching\u001b[1Cby\u001b[1C\u001b[38;2;177;185;249m(type, source)\u001b[1C\u001b[39mis\u001b[1Cclean\u001b[1Cfor\u001b[1Cexact\u001b[1Cmatches\u001b[1Cbut\r\u001b[1B  may need glob or prefix matching as event types grow (e.g., \u001b[38;2;177;185;249mdev.github.pr.*\u001b[39m). Too simple and we're back to \r\u001b[1B  hardcoding;\u001b[1Ctoo\u001b[1Cexpressive\u001b[1Cand\u001b[1Cwe've\u001b[1Cbuilt\u001b[1Ca\u001b[1CDSL.\u001b[1CMitigation:\u001b[1Cstart\u001b[1Cwith\u001b[1Cexact\u001b[1Cmatch,\u001b[1Cdesign\u001b[1Cthe\u001b[1Cregistry\r\u001b[1B  interface so glob can be added without breaking existing routes.                                           \r\u001b[2C\u001b[1B                                                                                                         \r\u001b[1B\u001b[38;2;136;136;136m──────────────────────────────────────────────────────────────────────────────────────────────"]
